# PostgreSQL (Neon / Aiven / Supabase)
# Copy to .env and add your connection string
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Example Neon:
# DATABASE_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Example Aiven:
# DATABASE_URL=postgresql://avnadmin:xxx@pg-xxx.aivencloud.com:port/defaultdb?sslmode=require
